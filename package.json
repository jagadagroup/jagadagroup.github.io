{
  "name": "magnalium",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node ./bin/www",
    "test": "jest --config jest.config.js",
    "test:e2e": "npx playwright test --config=playwright.config.js",
    "test:e2e:static": "npx playwright test --config=playwright.static.config.js",
    "test:all": "npm test && npm run test:e2e && npm run test:e2e:static",
    "test:smoke": "npx playwright test --config=playwright.config.js --project=desktop"
  },
  "dependencies": {
    "body-parser": "^1.18.3",
    "bootstrap": "^4.5.0",
    "cookie-parser": "~1.4.3",
    "debug": "~2.6.9",
    "express": "~4.16.0",
    "glob": "^7.1.2",
    "http-errors": "~1.6.2",
    "morgan": "^1.9.1",
    "node-sass-middleware": "0.11.0",
    "pug": "^2.0.0-beta11"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "html-webpack-plugin": "^4.3.0",
    "jest": "^30.4.2",
    "playwright": "^1.60.0",
    "serve": "^14.2.6",
    "webpack": "^4.43.0",
    "webpack-dev-middleware": "^3.1.3",
    "webpack-hot-middleware": "^2.22.3",
    "write-file-webpack-plugin": "^4.5.1"
  }
}
